# Supabase (required for poller and frontend)
SUPABASE_URL=
# service_role key — keep secret, poller-only
SUPABASE_SERVICE_KEY=

# Postgres connection string — used at runtime on Pi (direct PG mode) or locally for Alembic migrations
DATABASE_URL=

# Frontend Vite env vars (prefix must be VITE_)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
